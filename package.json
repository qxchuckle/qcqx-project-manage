{
  "name": "@qcqx/project-manage-monorepo",
  "private": true,
  "description": "qcqx-project-manage Monorepo 工作区",
  "license": "MIT",
  "author": {
    "name": "qcqx",
    "url": "https://github.com/qxchuckle"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qxchuckle/qcqx-project-manage.git"
  },
  "homepage": "https://github.com/qxchuckle/qcqx-project-manage#readme",
  "bugs": {
    "url": "https://github.com/qxchuckle/qcqx-project-manage/issues"
  },
  "keywords": [
    "qcqx",
    "project-manage",
    "vscode",
    "monorepo",
    "项目管理"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r run compile",
    "build:vscode": "pnpm --filter qcqx-project-manage run compile",
    "build:core": "pnpm --filter @qcqx/project-manage-core run build",
    "build:cli": "pnpm --filter @qcqx/project-manage-cli run build",
    "build:mcp": "pnpm --filter @qcqx/project-manage-mcp run build",
    "publish:mcp": "pnpm --filter @qcqx/project-manage-mcp publish --no-git-checks",
    "publish:skill": "pnpm --filter @qcqx/project-manage-skill publish",
    "watch": "pnpm --filter qcqx-project-manage run watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:fix": "prettier --write . --fix",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "check-types": "pnpm -r run check-types",
    "package": "pnpm --filter qcqx-project-manage run package",
    "publish:vscode": "pnpm --filter qcqx-project-manage run publish",
    "package:vsix": "pnpm --filter qcqx-project-manage run package-vsix"
  },
  "engines": {
    "node": ">=16",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@archoleat/prettier-define-config": "^1.2.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}