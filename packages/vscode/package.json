{
  "name": "qcqx-project-manage",
  "displayName": "项目管理(Project Manage)",
  "description": "一个更可靠、方便的项目管理插件",
  "publisher": "qcqx",
  "version": "1.6.0",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "publish": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
    "package-vsix": "vsce package --no-dependencies"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "项目",
    "管理",
    "project",
    "folder",
    "workspace",
    "switch",
    "manage",
    "mercurial"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/qxchuckle/qcqx-project-manage.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/logo.png",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qcqx-project-manage-panel",
          "title": "项目管理",
          "icon": "assets/manage.svg"
        }
      ]
    },
    "views": {
      "qcqx-project-manage-panel": [
        {
          "id": "project-list",
          "name": "项目列表"
        },
        {
          "id": "recent-folders",
          "name": "最近打开的文件夹",
          "visibility": "collapsed"
        },
        {
          "id": "local-git-projects",
          "name": "本地Git项目",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "local-git-projects",
        "contents": "未发现本地 Git 项目。\n请在配置文件中设置扫描目录。\n[打开配置文件](command:qcqx-project-manage.local-git-projects.open-config)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "qcqx-project-manage.project-list.lock",
          "when": "view == project-list && !config.qcqx-project-manage.project-list-lock",
          "group": "navigation@4"
        },
        {
          "command": "qcqx-project-manage.project-list.unlock",
          "when": "view == project-list && config.qcqx-project-manage.project-list-lock",
          "group": "navigation@5"
        },
        {
          "command": "qcqx-project-manage.project-list.locate-current-project",
          "when": "view == project-list",
          "group": "navigation@6"
        },
        {
          "command": "qcqx-project-manage.project-list.project-search",
          "when": "view == project-list",
          "group": "navigation@7"
        },
        {
          "command": "qcqx-project-manage.project-list.open-local-config",
          "when": "view == project-list",
          "group": "navigation@8"
        },
        {
          "command": "qcqx-project-manage.project-list.open-cache-config",
          "when": "view == project-list",
          "group": "navigation@9"
        },
        {
          "command": "qcqx-project-manage.recent-folders.refresh",
          "when": "view == recent-folders",
          "group": "navigation@1"
        },
        {
          "command": "qcqx-project-manage.recent-folders.search",
          "when": "view == recent-folders",
          "group": "navigation@2"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.refresh",
          "when": "view == local-git-projects",
          "group": "navigation@1"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.switch-view-mode",
          "when": "view == local-git-projects",
          "group": "navigation@2"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-config",
          "when": "view == local-git-projects",
          "group": "navigation@3"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-cache",
          "when": "view == local-git-projects",
          "group": "navigation@4"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.search",
          "when": "view == local-git-projects",
          "group": "navigation@5"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.locate-current-project",
          "when": "view == local-git-projects",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "qcqx-project-manage.project-list.rename-node",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "1_modification@1"
        },
        {
          "command": "qcqx-project-manage.project-list.edit-description",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "1_modification@2"
        },
        {
          "command": "qcqx-project-manage.project-list.delete-node",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "1_modification@3"
        },
        {
          "command": "qcqx-project-manage.project-list.open-link",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "2_modification@4"
        },
        {
          "command": "qcqx-project-manage.project-list.add-link",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "2_modification@5"
        },
        {
          "command": "qcqx-project-manage.project-list.save-active-editor-file",
          "when": "view == project-list && (viewItem == group)",
          "group": "1_modification@4"
        },
        {
          "command": "qcqx-project-manage.recent-folders.open-in-current-window",
          "when": "view == recent-folders && viewItem == recent-folder",
          "group": "inline@1"
        },
        {
          "command": "qcqx-project-manage.recent-folders.open-in-new-window",
          "when": "view == recent-folders && viewItem == recent-folder",
          "group": "inline@2"
        },
        {
          "command": "qcqx-project-manage.recent-folders.save-to-project-list",
          "when": "view == recent-folders && viewItem == recent-folder",
          "group": "inline@3"
        },
        {
          "command": "qcqx-project-manage.project-list.delete-link",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "2_modification@6"
        },
        {
          "command": "qcqx-project-manage.project-list.edit-in-local-config",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "3_modification@7"
        },
        {
          "command": "qcqx-project-manage.project-list.open-project-in-file-explorer",
          "when": "view == project-list && (viewItem == project || viewItem == file || viewItem == folder || viewItem == fs-file)",
          "group": "3_modification@8"
        },
        {
          "command": "qcqx-project-manage.project-list.open-project-in-terminal",
          "when": "view == project-list && (viewItem == project || viewItem == file || viewItem == folder || viewItem == fs-file)",
          "group": "3_modification@9"
        },
        {
          "command": "qcqx-project-manage.project-list.copy-path",
          "when": "view == project-list && (viewItem == project || viewItem == file || viewItem == folder || viewItem == fs-file)",
          "group": "3_modification@10"
        },
        {
          "command": "qcqx-project-manage.project-list.open-project-in-current-window",
          "when": "view == project-list && (viewItem == project || viewItem == folder)",
          "group": "inline@1"
        },
        {
          "command": "qcqx-project-manage.project-list.open-project-in-new-window",
          "when": "view == project-list && (viewItem == project || viewItem == folder)",
          "group": "inline@2"
        },
        {
          "command": "qcqx-project-manage.project-list.add-group",
          "when": "view == project-list && (viewItem == tip || viewItem == group)",
          "group": "inline@3"
        },
        {
          "command": "qcqx-project-manage.project-list.add-project",
          "when": "view == project-list && (viewItem == tip || viewItem == group)",
          "group": "inline@4"
        },
        {
          "command": "qcqx-project-manage.project-list.add-current-project",
          "when": "view == project-list && (viewItem == tip || viewItem == group)",
          "group": "inline@5"
        },
        {
          "submenu": "qcqx-project-manage.project-list-more-actions",
          "when": "view == project-list && (viewItem == tip || viewItem == project || viewItem == file || viewItem == group)",
          "group": "inline@6"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-in-current-window",
          "when": "view == local-git-projects && viewItem =~ /^local-git-project$|^local-git-path-folder$/",
          "group": "inline@1"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-in-new-window",
          "when": "view == local-git-projects && viewItem =~ /^local-git-project$|^local-git-path-folder$/",
          "group": "inline@2"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.save-to-project-list",
          "when": "view == local-git-projects && viewItem =~ /^local-git-project$|^local-git-path-folder$/",
          "group": "inline@3"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-in-terminal",
          "when": "view == local-git-projects && viewItem =~ /^local-git-project$|^local-git-path-folder$/",
          "group": "1_actions@1"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-in-file-explorer",
          "when": "view == local-git-projects && viewItem =~ /^local-git-project$|^local-git-path-folder$/",
          "group": "1_actions@2"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.copy-path",
          "when": "view == local-git-projects && viewItem =~ /^local-git-project$|^local-git-path-folder$/",
          "group": "1_actions@3"
        },
        {
          "command": "qcqx-project-manage.local-git-projects.open-remote",
          "when": "view == local-git-projects && viewItem == local-git-project",
          "group": "1_actions@4"
        }
      ],
      "qcqx-project-manage.project-list-more-actions": [
        {
          "command": "qcqx-project-manage.project-list.rename-node",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "1_modification@1"
        },
        {
          "command": "qcqx-project-manage.project-list.edit-description",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "1_modification@2"
        },
        {
          "command": "qcqx-project-manage.project-list.delete-node",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "1_modification@3"
        },
        {
          "command": "qcqx-project-manage.project-list.save-active-editor-file",
          "when": "view == project-list && (viewItem == tip || viewItem == group)",
          "group": "1_modification@4"
        },
        {
          "command": "qcqx-project-manage.project-list.open-link",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "2_modification@4"
        },
        {
          "command": "qcqx-project-manage.project-list.add-link",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "2_modification@5"
        },
        {
          "command": "qcqx-project-manage.project-list.delete-link",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "2_modification@6"
        },
        {
          "command": "qcqx-project-manage.project-list.edit-in-local-config",
          "when": "view == project-list && (viewItem == group || viewItem == project || viewItem == file)",
          "group": "3_modification@7"
        },
        {
          "command": "qcqx-project-manage.project-list.open-project-in-file-explorer",
          "when": "view == project-list && (viewItem == project || viewItem == file || viewItem == folder)",
          "group": "3_modification@8"
        },
        {
          "command": "qcqx-project-manage.project-list.open-project-in-terminal",
          "when": "view == project-list && (viewItem == project || viewItem == file || viewItem == folder || viewItem == fs-file)",
          "group": "3_modification@9"
        },
        {
          "command": "qcqx-project-manage.project-list.copy-path",
          "when": "view == project-list && (viewItem == project || viewItem == file || viewItem == folder || viewItem == fs-file)",
          "group": "3_modification@10"
        }
      ]
    },
    "submenus": [
      {
        "id": "qcqx-project-manage.project-list-more-actions",
        "label": "更多操作",
        "icon": "$(ellipsis)"
      }
    ],
    "commands": [
      {
        "command": "qcqx-project-manage.project-list.add-group",
        "title": "添加分组",
        "icon": "$(new-folder)"
      },
      {
        "command": "qcqx-project-manage.project-list.add-project",
        "title": "添加项目",
        "icon": "$(new-file)"
      },
      {
        "command": "qcqx-project-manage.project-list.add-current-project",
        "title": "添加当前项目",
        "icon": "$(save)"
      },
      {
        "command": "qcqx-project-manage.project-list.delete-node",
        "title": "删除",
        "icon": "$(trash)"
      },
      {
        "command": "qcqx-project-manage.project-list.rename-node",
        "title": "重命名",
        "icon": "$(pencil)"
      },
      {
        "command": "qcqx-project-manage.project-list.edit-description",
        "title": "编辑描述",
        "icon": "$(comments-view-icon)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-project-in-current-window",
        "title": "在当前窗口打开项目",
        "icon": "$(window)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-project-in-new-window",
        "title": "在新窗口打开项目",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-project-in-file-explorer",
        "title": "在文件管理器中打开项目",
        "icon": "$(explorer-view-icon)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-project-in-terminal",
        "title": "在终端打开项目",
        "icon": "$(terminal-view-icon)"
      },
      {
        "command": "qcqx-project-manage.project-list.lock",
        "title": "锁定项目列表",
        "icon": "$(lock)"
      },
      {
        "command": "qcqx-project-manage.project-list.unlock",
        "title": "解锁项目列表",
        "icon": "$(unlock)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-local-config",
        "title": "编辑项目列表",
        "icon": "$(edit)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-cache-config",
        "title": "打开配置文件",
        "icon": "$(gear)"
      },
      {
        "command": "qcqx-project-manage.project-list.expand-all",
        "title": "展开所有",
        "icon": "$(expand-all)"
      },
      {
        "command": "qcqx-project-manage.project-list.collapse-all",
        "title": "折叠所有",
        "icon": "$(collapse-all)"
      },
      {
        "command": "qcqx-project-manage.project-list.locate-current-project",
        "title": "定位当前项目",
        "icon": "$(location)"
      },
      {
        "command": "qcqx-project-manage.project-list.edit-in-local-config",
        "title": "在配置中编辑",
        "icon": "$(edit)"
      },
      {
        "command": "qcqx-project-manage.project-list.add-link",
        "title": "添加关联链接",
        "icon": "$(link)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-link",
        "title": "打开关联链接",
        "icon": "$(link)"
      },
      {
        "command": "qcqx-project-manage.project-list.delete-link",
        "title": "删除关联链接",
        "icon": "$(link)"
      },
      {
        "command": "qcqx-project-manage.project-list.open-path-in-file-explorer",
        "title": "在文件管理器中打开路径",
        "icon": "$(explorer-view-icon)"
      },
      {
        "command": "qcqx-project-manage.project-list.copy-path",
        "title": "复制路径",
        "icon": "$(copy)"
      },
      {
        "command": "qcqx-project-manage.project-list.project-search",
        "title": "项目搜索",
        "icon": "$(search)"
      },
      {
        "command": "qcqx-project-manage.project-list.locate-project-by-id",
        "title": "定位指定id项目"
      },
      {
        "command": "qcqx-project-manage.project-list.open-file-in-current-editor",
        "title": "在当前编辑器打开文件",
        "icon": "$(file)"
      },
      {
        "command": "qcqx-project-manage.project-list.save-active-editor-file",
        "title": "添加当前编辑文件"
      },
      {
        "command": "qcqx-project-manage.recent-folders.open-in-current-window",
        "title": "在当前窗口打开",
        "icon": "$(window)"
      },
      {
        "command": "qcqx-project-manage.recent-folders.open-in-new-window",
        "title": "在新窗口打开",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "qcqx-project-manage.recent-folders.save-to-project-list",
        "title": "保存到项目列表",
        "icon": "$(add)"
      },
      {
        "command": "qcqx-project-manage.recent-folders.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "qcqx-project-manage.recent-folders.search",
        "title": "搜索最近文件夹",
        "icon": "$(search)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.switch-view-mode",
        "title": "切换视图模式",
        "icon": "$(list-tree)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.search",
        "title": "搜索Git项目",
        "icon": "$(search)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.locate-current-project",
        "title": "定位当前项目",
        "icon": "$(location)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-config",
        "title": "打开配置文件",
        "icon": "$(gear)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-cache",
        "title": "打开缓存文件",
        "icon": "$(database)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-in-current-window",
        "title": "在当前窗口打开",
        "icon": "$(window)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-in-new-window",
        "title": "在新窗口打开",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.save-to-project-list",
        "title": "保存到项目列表",
        "icon": "$(add)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-in-terminal",
        "title": "在终端打开",
        "icon": "$(terminal-view-icon)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-in-file-explorer",
        "title": "在文件管理器中打开",
        "icon": "$(explorer-view-icon)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.copy-path",
        "title": "复制路径",
        "icon": "$(copy)"
      },
      {
        "command": "qcqx-project-manage.local-git-projects.open-remote",
        "title": "打开远程仓库",
        "icon": "$(globe)"
      }
    ],
    "configuration": {
      "title": "qcqx-project-manage",
      "properties": {
        "qcqx-project-manage.project-list-lock": {
          "type": "boolean",
          "default": false,
          "description": "是否锁定项目列表"
        },
        "qcqx-project-manage.recent-folders-max": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "最近打开的文件夹视图最多显示数量"
        },
        "qcqx-project-manage.local-git-view-mode": {
          "type": "string",
          "default": "flat",
          "enum": [
            "flat",
            "category",
            "path"
          ],
          "enumDescriptions": [
            "按名称平铺展示所有 Git 项目",
            "按配置中的分类分组展示",
            "按文件路径层级展示，自动合并单子目录"
          ],
          "description": "本地 Git 项目视图模式"
        }
      }
    }
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/picomatch": "^4.0.3",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@qcqx/project-manage-core": "workspace:*",
    "picomatch": "^4.0.4",
    "sql.js": "^1.14.1"
  }
}
