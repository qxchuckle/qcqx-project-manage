{
  "name": "@qcqx/project-manage-core",
  "version": "0.1.0",
  "private": true,
  "description": "qcqx-project-manage 共享核心库",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "license": "MIT",
  "author": {
    "name": "qcqx",
    "url": "https://github.com/qxchuckle"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qxchuckle/qcqx-project-manage.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/qxchuckle/qcqx-project-manage/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/qxchuckle/qcqx-project-manage/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "qcqx",
    "project-manage",
    "core",
    "vscode"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/git-url-parse": "^16.0.2",
    "@types/node": "^16.18.0",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "git-url-parse": "^16.1.0",
    "picomatch": "^4.0.4",
    "simple-git": "^3.35.2"
  }
}
